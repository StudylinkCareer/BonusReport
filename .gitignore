# ----- Python -----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
*.egg
MANIFEST
build/
dist/
develop-eggs/
downloads/
eggs/
parts/
sdist/
var/
wheels/
share/python-wheels/

# ----- Virtual environments -----
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/
backend/venv/

# ----- Environment variables (CRITICAL — DB credentials live here) -----
.env
.env.*
!.env.example
*.env

# ----- IDEs / editors -----
.vscode/
.idea/
*.swp
*.swo
*~

# ----- OS files -----
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ----- Testing / coverage (artifacts only — does NOT exclude tests/ source) -----
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
*.py,cover
.hypothesis/
test_baseline.txt
test_collection.txt
collect_only.txt

# ----- Jupyter -----
.ipynb_checkpoints/

# ----- Frontend (Node / Next.js) -----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.next/
.nuxt/
.cache/
.turbo/
frontend/out/

# ----- Logs -----
*.log
logs/
backend/logs/

# ----- Local databases -----
*.db
*.sqlite
*.sqlite3

# ----- Backup files -----
*.bak
*.tmp
*_bak.py

# ----- Project-specific scratch directories -----
Supporting Content/
DocumentReview/
backend/docs/DocumentReview/

# ----- Regression outputs at repo root only (keeps backend/tools/regression_*.py tracked) -----
/regression_*.xlsx
/regression_*.csv
/regression_*.ps1